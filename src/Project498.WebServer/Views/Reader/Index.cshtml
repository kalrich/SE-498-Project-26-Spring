@model Project498.WebServer.Models.Comic

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="reader-page">
    <div class="reader-toolbar">
        <div>
            <h2 class="reader-title">@Model.Title</h2>
            <p class="reader-meta">@Model.Author</p>
        </div>

        <div class="reader-toolbar-actions">
            <a href="/Comics/Details?id=@Model.Id" class="btn btn-light small">Back</a>
        </div>
    </div>

    <div class="pdfjs-toolbar">
        <button id="prev-page" class="btn btn-light small" type="button">Prev</button>
        <span class="page-indicator">Page <span id="page-num">1</span> of <span id="page-count">?</span></span>
        <button id="next-page" class="btn btn-light small" type="button">Next</button>
    </div>

    <div class="pdfjs-viewer-wrap">
        <canvas id="pdf-canvas"></canvas>
    </div>

    <p id="pdf-error" class="error-text" style="display:none;"></p>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
    pdfjsLib.GlobalWorkerOptions.workerSrc =
        "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";

    const url = "@Model.PdfPath";
    let pdfDoc = null;
    let pageNum = 1;
    const scale = 1.3;
    const canvas = document.getElementById("pdf-canvas");
    const ctx = canvas.getContext("2d");
    const errorEl = document.getElementById("pdf-error");

    function showError(message) {
        errorEl.style.display = "block";
        errorEl.textContent = message;
        console.error(message);
    }

    function renderPage(num) {
        pdfDoc.getPage(num).then(function(page) {
            const viewport = page.getViewport({ scale: scale });
            canvas.height = viewport.height;
            canvas.width = viewport.width;

            const renderContext = {
                canvasContext: ctx,
                viewport: viewport
            };

            page.render(renderContext);
            document.getElementById("page-num").textContent = num;
        }).catch(function(err) {
            showError("Could not render page: " + err.message);
        });
    }

    pdfjsLib.getDocument(url).promise.then(function(pdfDoc_) {
        pdfDoc = pdfDoc_;
        document.getElementById("page-count").textContent = pdfDoc.numPages;
        renderPage(pageNum);
    }).catch(function(err) {
        showError("Could not load PDF: " + err.message);
    });

    document.getElementById("prev-page").addEventListener("click", function() {
        if (!pdfDoc || pageNum <= 1) return;
        pageNum--;
        renderPage(pageNum);
    });

    document.getElementById("next-page").addEventListener("click", function() {
        if (!pdfDoc || pageNum >= pdfDoc.numPages) return;
        pageNum++;
        renderPage(pageNum);
    });
</script>