@model Project498.WebServer.Models.LoginViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="auth-page">
    <div class="auth-card">
        <h2 class="auth-title">Welcome Back!</h2>
        <p class="auth-subtitle">Log in to your account</p>

        <div class="divider"></div>

        @if (ViewBag.Error != null)
        {
            <p class="error-text">@ViewBag.Error</p>
        }

        <form class="auth-form" method="post" asp-controller="Auth" asp-action="Login">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" placeholder="your@email.com" />
            <span asp-validation-for="Email" class="error-text"></span>

            <label asp-for="Password">Password</label>
            <input asp-for="Password" type="password" placeholder="••••••••" />
            <span asp-validation-for="Password" class="error-text"></span>

            <a href="#" class="forgot-link">Forgot password?</a>

            <button type="submit" class="btn btn-dark auth-submit">Log In</button>

            <p class="auth-footer">
                Don't have an account?
                <a href="/Auth/Signup">Sign up</a>
            </p>
        </form>
    </div>
</section>