@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var username = ViewBag.Username as string ?? "Guest User";
    var email = ViewBag.Email as string ?? "guest@example.com";

    var initials = string.Join("", username
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Select(x => x[0]))
        .ToUpper();

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "GU";
    }
}

<section class="profile-page">
    <div class="profile-header">
        <h1>My Profile</h1>
        <p>View your account information and reading activity.</p>
    </div>

    <div class="profile-grid">
        <div class="profile-card main-profile-card">
            <div class="profile-avatar-large">@initials</div>

            <div class="profile-info-block">
                <h2>@username</h2>
                <p class="profile-email">@email</p>
            </div>
        </div>

        <div class="profile-card">
            <h3>Account Information</h3>

            <div class="profile-detail-row">
                <span class="profile-label">Username</span>
                <span class="profile-value">@username</span>
            </div>

            <div class="profile-detail-row">
                <span class="profile-label">Email</span>
                <span class="profile-value">@email</span>
            </div>

            <div class="profile-detail-row">
                <span class="profile-label">Membership</span>
                <span class="profile-value">Marvel·ous Reads User</span>
            </div>
        </div>

        <div class="profile-card">
            <h3>Reading Activity</h3>

            <div class="profile-detail-row">
                <span class="profile-label">Currently Reading</span>
                <span class="profile-value">See My Shelves</span>
            </div>

            <div class="profile-detail-row">
                <span class="profile-label">Recommendations</span>
                <span class="profile-value">Enabled</span>
            </div>

            <div class="profile-detail-row">
                <span class="profile-label">Reader Progress</span>
                <span class="profile-value">Mock Mode</span>
            </div>
        </div>
    </div>
</section>