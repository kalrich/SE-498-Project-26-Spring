@using Microsoft.AspNetCore.Http

@{
    var username = Context.Session.GetString("Username");
    var currentQuery = Context.Request.Query["query"].ToString();

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var isExploreActive =
        currentController == "Explore" ||
        currentController == "Home" ||
        currentController == "Comics" ||
        currentController == "Reader";

    var isRecommendationsActive = currentController == "Recommendations";
    var isShelvesActive = currentController == "Shelves";

    var initials = "";
    if (!string.IsNullOrWhiteSpace(username))
    {
        initials = string.Join("", username
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x[0]))
            .ToUpper();

        if (string.IsNullOrWhiteSpace(initials))
        {
            initials = "U";
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Marvel·ous Reads</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

<header class="topbar">
    <a class="brand" href="/">Marvel·ous Reads</a>

    <form class="search-wrap" method="get" action="/Explore">
        <input
            class="search-bar"
            type="text"
            name="query"
            value="@currentQuery"
            placeholder="Search books, characters, comics..." />
    </form>

    <nav class="top-actions">
        @if (!string.IsNullOrEmpty(username))
        {
            <a class="nav-text-link @(isExploreActive ? "active-nav" : "")" href="/Explore">
                Explore
            </a>

            <a class="nav-text-link @(isRecommendationsActive ? "active-nav" : "")" href="/Recommendations">
                Recommendations
            </a>

            <a class="nav-text-link @(isShelvesActive ? "active-nav" : "")" href="/Shelves">
                My Shelves
            </a>

            <a class="logout-link" href="/Auth/Logout">Logout</a>

            <a class="nav-avatar profile-link" href="/Profile">@initials</a>
        }
        else
        {
            <a class="explore-link @(isExploreActive ? "active-nav" : "")" href="/Explore">
                Explore
            </a>

            <a class="btn btn-light small" href="/Auth/Login">Login</a>
            <a class="btn btn-dark small" href="/Auth/Signup">Sign Up</a>
        }
    </nav>
</header>

<main class="page-shell">
    @RenderBody()
</main>

</body>
</html>